    "brute:mt3:8w": "node find-route-bruteforce.js --algorithm=bfs --to-floor=MT3 --workers=8 --max-expanded=200000 --fail-on-miss --resource-pocket-mode=off --fight-to-levelup=0",
    "perf:brute:8w": "node find-route-bruteforce.js --algorithm=bfs --to-floor=MT5 --workers=8 --perf=1 --resource-pocket-mode=off --fight-to-levelup=0",
