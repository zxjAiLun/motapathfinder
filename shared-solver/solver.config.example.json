{
  "version": 1,
  "project": {
    "id": "main-tower"
  },
  "route": {
    "floorOrder": ["MT1", "MT2", "MT3", "MT4", "MT5", "MT6", "MT7", "MT8", "MT9", "MT10", "MT11"],
    "startFloor": "MT1",
    "targetFloor": "MT11"
  },
  "profile": "linear-main",
  "profiles": {
    "linear-main": {
      "extends": "resource-prep-main",
      "defaults": {
        "resourcePocketMode": "lite",
        "resourceCluster": true,
        "resourceClusterMode": "normal",
        "resourceChain": true,
        "resourceChainFloors": ["MT2"],
        "fightToLevelUp": true,
        "searchGraph": "macro",
        "checkpointReuse": "auto",
        "checkpointSave": true,
        "confluence": true,
        "confluenceRoutePolicy": "slack",
        "confluenceRouteSlack": 12,
        "confluenceRepresentatives": 3,
        "confluenceMinFloor": 1
      }
    },
    "resource-prep-main": {
      "extends": "stage-mt1-mt11-resource-prep",
      "defaults": {
        "resourcePocketMode": "lite",
        "resourceCluster": true,
        "resourceClusterMode": "normal",
        "resourceChain": false,
        "fightToLevelUp": true,
        "searchGraph": "hybrid",
        "checkpointReuse": "auto",
        "checkpointSave": true,
        "confluence": true,
        "confluenceRoutePolicy": "slack",
        "confluenceRouteSlack": 12,
        "confluenceRepresentatives": 3,
        "confluenceMinFloor": 1
      }
    },
    "debug-local-resource": {
      "extends": "resource-prep-main",
      "defaults": {
        "resourcePocketMode": "deep",
        "resourceCluster": true,
        "resourceClusterMode": "deep",
        "resourceChain": false,
        "fightToLevelUp": true,
        "searchGraph": "hybrid",
        "checkpointReuse": "off",
        "checkpointSave": false,
        "confluence": true,
        "confluenceRoutePolicy": "slack",
        "confluenceRouteSlack": 12,
        "confluenceRepresentatives": 3,
        "confluenceMinFloor": 1
      }
    }
  },
  "checkpoints": {
    "enabled": true,
    "path": "solver/checkpoints/linear-main.checkpoint-skyline.json"
  }
}
